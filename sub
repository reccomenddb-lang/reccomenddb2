<script>
// --- Data Storage ---
const cardData = {
  hilton: {
    name: "ヒルトン・オナーズ アメックス・プレミアム",
    fee: "66,000円",
    baseStatus: "ヒルトン・ゴールド (朝食無料 / 部屋UP)",
