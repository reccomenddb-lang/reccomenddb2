// --- Core Interaction Handling: Spend Simulator ---
function initSimulator() {
  const slider = document.getElementById('spend-slider');
  const spendDisplay = document.getElementById('spend-display');
  const statusBox = document.getElementById('status-box');
  const statusBar = document.getElementById('status-bar');
  const statusIcon = document.getElementById('status-icon');
  const statusName = document.getElementById('status-name');
  const statusDesc = document.getElementById('status-desc');
  const freeNightDisplay = document.getElementById('free-night-display');
  const freeNightValue = document.getElementById('free-night-value');
  const pointsDisplay = document.getElementById('points-display');
  const pointsValue = document.getElementById('points-value');
  const roiDisplay = document.getElementById('roi-display');

  function updateSimulator() {
    const spend = parseInt(slider.value);
    spendDisplay.textContent = `${spend}万円`;

    // Logic Variables
    let points = spend * 10000 * 0.03; // 3% return
    let pValue = points * 0.5; // Assume 1pt = 0.5 JPY value
    
    let freeNights = 1; // Base renewal
    if (spend >= 300) freeNights = 2; // Hit 3M hurdle
    let fnValue = freeNights * 50000; // Assume 50k JPY per night

    let status = 'Gold';
    if (spend >= 200) status = 'Diamond'; // Hit 2M hurdle
    let sValue = status === 'Diamond' ? 80000 : 30000; // Value of status

    // Update DOM
    pointsDisplay.textContent = `${points.toLocaleString()} pt`;
    pointsValue.textContent = `(約${pValue.toLocaleString()}円相当)`;
    
    freeNightDisplay.textContent = `${freeNights}泊分`;
    freeNightValue.textContent = `(約${fnValue.toLocaleString()}円相当)`;

    if (status === 'Diamond') {
      statusBox.className = "bg-stone-50 rounded-xl p-6 text-center flex flex-col justify-center items-center relative overflow-hidden transition-colors duration-300 border-2 border-premium-gold";
      statusBar.className = "absolute top-0 left-0 w-full h-1 bg-premium-gold";
      statusIcon.textContent = '💎';
      statusName.textContent = 'ヒルトン・ダイヤモンド';
      statusDesc.textContent = '朝食無料 ＋ ラウンジアクセス ＋ スイートUP';
      statusDesc.className = 'text-sm font-bold text-green-700 bg-green-100 px-4 py-1 rounded-full inline-block';
    } else {
      statusBox.className = "bg-stone-100 rounded-xl p-6 text-center flex flex-col justify-center items-center relative overflow-hidden transition-colors duration-300";
      statusBar.className = "absolute top-0 left-0 w-full h-1 bg-premium-muted";
      statusIcon.textContent = '🥇';
      statusName.textContent = 'ヒルトン・ゴールド';
      statusDesc.textContent = '朝食無料 ＋ スタンダードルームUP';
      statusDesc.className = 'text-sm font-medium text-premium-muted bg-stone-200 px-4 py-1 rounded-full inline-block';
    }

    let totalValue = pValue + fnValue + sValue;
    let roi = totalValue - 66000;

    if (roi >= 0) {
      roiDisplay.textContent = `+${roi.toLocaleString()}円`;
      roiDisplay.className = "text-3xl font-serif font-bold text-green-600";
    } else {
      roiDisplay.textContent = `${roi.toLocaleString()}円`;
      roiDisplay.className = "text-3xl font-serif font-bold text-red-600";
    }
  }

  slider.addEventListener('input', updateSimulator);
  updateSimulator(); // Init on load
}

