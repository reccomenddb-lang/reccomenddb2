// --- Core Interaction Handling: Accordion ---
function toggleAccordion(btn) {
  const content = btn.nextElementSibling;
  const icon = btn.querySelector('span:last-child');
  
  // Close all other accordions (optional, but good for focus)
  const allContents = document.querySelectorAll('.accordion-content');
  const allIcons = document.querySelectorAll('button > span:last-child');
  
  allContents.forEach((c) => {
    if (c !== content && c.classList.contains('active')) {
      c.classList.remove('active');
      c.style.maxHeight = null;
    }
  });
  allIcons.forEach((i) => {
    if (i !== icon) {
      i.innerHTML = '&#43;'; // Plus
      i.style.transform = 'rotate(0deg)';
    }
  });

  // Toggle current
  if (content.classList.contains('active')) {
    content.classList.remove('active');
    content.style.maxHeight = null;
    icon.innerHTML = '&#43;';
    icon.style.transform = 'rotate(0deg)';
  } else {
    content.classList.add('active');
    content.style.maxHeight = content.scrollHeight + "px";
    icon.innerHTML = '&minus;'; // Minus
    icon.style.transform = 'rotate(180deg)';
  }
}

// --- Chart.js Initialization ---
function initChart() {
  const ctx = document.getElementById('comparisonChart').getContext('2d');
  
  // Data aligning with the narrative
  const labels = ['ヒルトン プレミアム', 'マリオット プレミアム', 'アメックスG プリファード', 'SMCC Pt プリファード'];
  const annualFees = [66000, 49500, 39600, 33000];
  // 0 means not applicable or no lounge benefit via spend
  const loungeHurdles = [2000000, 4000000, 0, 0]; 

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        {
          label: '年会費 (左軸: 円)',
          data: annualFees,
          backgroundColor: '#d6d3d1', // stone-300
          borderColor: '#a8a29e', // stone-400
          borderWidth: 1,
          yAxisID: 'y',
          order: 2
        },
        {
          label: 'ラウンジ到達決済額 (右軸: 万円)',
          data: loungeHurdles,
          type: 'line',
          backgroundColor: '#d97706', // premium-gold
          borderColor: '#d97706',
          borderWidth: 3,
          pointBackgroundColor: '#fff',
          pointBorderColor: '#d97706',
          pointBorderWidth: 3,
          pointRadius: 6,
          pointHoverRadius: 8,
          yAxisID: 'y1',
          order: 1
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      plugins: {
        legend: {
          position: 'top',
          labels: { font: { family: 'sans-serif', size: 12 } }
        },
        tooltip: {
          backgroundColor: 'rgba(41, 37, 36, 0.9)', // premium-dark
          titleFont: { size: 14 },
          bodyFont: { size: 13 },
          callbacks: {
            label: function(context) {
              let label = context.dataset.label || '';
              if (label) { label += ': '; }
              if (context.datasetIndex === 0) {
                label += context.raw.toLocaleString() + ' 円';
              } else {
                if (context.raw === 0) {
                  label += '該当なし（決済での付帯不可）';
                } else {
                  label += (context.raw / 10000).toLocaleString() + ' 万円';
                }
              }
              return label;
            }
          }
        }
      },
      scales: {
        y: {
          type: 'linear',
          display: true,
          position: 'left',
          title: { display: true, text: '年会費 (円)', color: '#78716c' },
          grid: { color: '#f5f5f4' },
          min: 0,
          max: 80000
        },
        y1: {
          type: 'linear',
          display: true,
          position: 'right',
          title: { display: true, text: 'ラウンジ到達決済額 (万円)', color: '#d97706' },
          grid: { drawOnChartArea: false }, // only draw grid lines for one axis
          min: 0,
          max: 5000000,
          ticks: {
            callback: function(value) {
              return value / 10000 + '万';
            }
          }
        }
      }
    }
  });
}

// --- Initialize App ---
document.addEventListener('DOMContentLoaded', () => {
  initSimulator();
  // Init tabs with first element
  switchTab('hilton', document.getElementById('tab-buttons').firstElementChild);
  initChart();
  
  // Open the first accordion by default
  const firstAccordion = document.querySelector('#accordion-container button');
  if(firstAccordion) toggleAccordion(firstAccordion);
});
</script>
